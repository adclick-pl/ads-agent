# --- Google Ads API Credentials ---
# Copy this file to `.env` in the same folder and fill in your values.
# How to obtain these: see README.md → "Setup Google Ads API".

GADS_DEVELOPER_TOKEN=YOUR_DEVELOPER_TOKEN
GADS_CLIENT_ID=YOUR_OAUTH_CLIENT_ID.apps.googleusercontent.com
GADS_CLIENT_SECRET=YOUR_OAUTH_CLIENT_SECRET
GADS_REFRESH_TOKEN=YOUR_OAUTH_REFRESH_TOKEN

# 10-digit MCC / manager account number (no dashes). Required for agency/MCC setups.
GADS_LOGIN_CUSTOMER_ID=1234567890
# Default child account used when no --customer is passed (no dashes).
GADS_DEFAULT_CUSTOMER_ID=1234567890
